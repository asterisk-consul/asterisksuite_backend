  created_by         String?              @db.Uuid
  updated_by         String?              @db.Uuid
  deleted_by         String?              @db.Uuid
  product_components product_components[]
}

model product_variants {
  id                       String                     @id @default(uuid()) @db.Uuid
  product_id               String                     @db.Uuid
  name                     String?                    @db.VarChar(255)
  sku                      String?                    @db.VarChar(100)
  thickness_mm             Decimal?                   @db.Decimal(10, 3)
  density_kg_m3            Decimal?                   @db.Decimal(12, 3)
  weight_kg                Decimal?                   @db.Decimal(12, 3)
  cost_price               Decimal?                   @db.Decimal(15, 2)
  sale_price               Decimal?                   @db.Decimal(15, 2)
  active                   Boolean                    @default(true)
  created_at               DateTime                   @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @updatedAt @db.Timestamp(6)
  deleted_at               DateTime?
  created_by               String?                    @db.Uuid
  updated_by               String?                    @db.Uuid
  deleted_by               String?                    @db.Uuid
  products                 products                   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  product_components       product_components[]
  product_attribute_values product_attribute_values[]
  productCostBreakdowns    product_cost_breakdowns[]

  @@index([product_id])
}

model product_components {
  //producto raiz 
  id                   String            @id @default(uuid()) @db.Uuid
  parent_product_id    String            @db.Uuid
  child_product_id     String            @db.Uuid
  child_variant_id     String?           @db.Uuid
  quantity             Decimal           @db.Decimal(12, 3)
  unit_id              String?           @db.Uuid
  length_mm            Decimal?          @db.Decimal(12, 3)
  width_mm             Decimal?          @db.Decimal(12, 3)
  height_mm            Decimal?          @db.Decimal(12, 3)
  calculated_weight_kg Decimal?          @db.Decimal(12, 3)
  waste_percentage     Decimal?          @db.Decimal(5, 2)
  active               Boolean           @default(true)
  created_at           DateTime          @default(now()) @db.Timestamp(6)
  updated_at           DateTime?         @updatedAt @db.Timestamp(6)
  deleted_at           DateTime?
  created_by           String?           @db.Uuid
  updated_by           String?           @db.Uuid
  deleted_by           String?           @db.Uuid
  parent_product       products          @relation("parent_product", fields: [parent_product_id], references: [id], onDelete: Cascade)
  child_product        products          @relation("child_product", fields: [child_product_id], references: [id])
  child_variant        product_variants? @relation(fields: [child_variant_id], references: [id])
  units                units?            @relation(fields: [unit_id], references: [id])

  @@index([parent_product_id])
  @@index([child_product_id])
  @@index([child_variant_id])
}

model categories {
  id                 String               @id @default(uuid()) @db.Uuid
  name               String               @db.VarChar(255)
  slug               String?              @db.VarChar(255)
  parent_id          String?              @db.Uuid
  active             Boolean              @default(true)
  //ver de agregar types como en flow
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @updatedAt @db.Timestamp(6)
  deleted_at         DateTime?
  created_by         String?              @db.Uuid
  updated_by         String?              @db.Uuid
  deleted_by         String?              @db.Uuid
  parent             categories?          @relation("category_tree", fields: [parent_id], references: [id])
  children           categories[]         @relation("category_tree")
  product_categories product_categories[]

  @@index([parent_id])
}

model product_categories {
  product_id  String     @db.Uuid
  category_id String     @db.Uuid
  created_at  DateTime   @default(now()) @db.Timestamp(6)
  updated_at  DateTime?  @updatedAt @db.Timestamp(6)
  deleted_at  DateTime?
  created_by  String?    @db.Uuid
  updated_by  String?    @db.Uuid
  deleted_by  String?    @db.Uuid
  products    products   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([product_id, category_id])
  @@index([category_id])
}

model tags {
  id           String         @id @default(uuid()) @db.Uuid
  name         String         @unique @db.VarChar(100)
  active       Boolean        @default(true)
  created_at   DateTime       @default(now()) @db.Timestamp(6)
  updated_at   DateTime?      @updatedAt @db.Timestamp(6)
  deleted_at   DateTime?
  created_by   String?        @db.Uuid
  updated_by   String?        @db.Uuid
  deleted_by   String?        @db.Uuid
  product_tags product_tags[]
}

model product_tags {
  product_id String    @db.Uuid
  tag_id     String    @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @updatedAt @db.Timestamp(6)
  deleted_at DateTime?
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid
  deleted_by String?   @db.Uuid
  products   products  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  tags       tags      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([product_id, tag_id])
}

model attributes {
  id                       String                     @id @default(uuid()) @db.Uuid
  name                     String                     @db.VarChar(100)
  code                     String                     @unique @db.VarChar(100)
  type                     AttributeType
  active                   Boolean                    @default(true)
  created_at               DateTime                   @default(now()) @db.Timestamp(6)
  updated_at               DateTime?                  @updatedAt @db.Timestamp(6)
  deleted_at               DateTime?
  created_by               String?                    @db.Uuid
  updated_by               String?                    @db.Uuid
  deleted_by               String?                    @db.Uuid
  product_attribute_values product_attribute_values[]
}

model product_attribute_values {
  id               String            @id @default(uuid()) @db.Uuid
  product_id       String?           @db.Uuid
  variant_id       String?           @db.Uuid
  attribute_id     String            @db.Uuid
  text_value       String?
  number_value     Decimal?          @db.Decimal(15, 3)
  boolean_value    Boolean?
  created_at       DateTime          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?         @updatedAt @db.Timestamp(6)
  deleted_at       DateTime?
  created_by       String?           @db.Uuid
  updated_by       String?           @db.Uuid
  deleted_by       String?           @db.Uuid
  products         products?         @relation(fields: [product_id], references: [id])
  product_variants product_variants? @relation(fields: [variant_id], references: [id])
  attributes       attributes        @relation(fields: [attribute_id], references: [id])

  @@index([product_id])
  @@index([variant_id])
  @@index([attribute_id])
}

model accounts {
  id                 String      @id @default(uuid()) @db.Uuid
  code               String      @db.VarChar(50)
  name               String      @db.VarChar(255)
  account_type       AccountType
  parent_id          String?     @db.Uuid
  active             Boolean     @default(true)
  created_at         DateTime    @default(now()) @db.Timestamp(6)
  updated_at         DateTime?   @updatedAt @db.Timestamp(6)
  deleted_at         DateTime?
  created_by         String?     @db.Uuid
  updated_by         String?     @db.Uuid
  deleted_by         String?     @db.Uuid
  parent             accounts?   @relation("account_tree", fields: [parent_id], references: [id])
  children           accounts[]  @relation("account_tree")
  income_products    products[]  @relation("product_income_account")
  expense_products   products[]  @relation("product_expense_account")
  inventory_products products[]  @relation("product_inventory_account")

  @@unique([code])
  @@index([parent_id])
}

enum ProductCostSource {
  MANUAL
  BOM
  ENGINEERING
  PURCHASE
  RATE
}

model product_costs {
  id String @id @default(uuid()) @db.Uuid

  product_id  String @db.Uuid
  currency_id String @db.Uuid

  cost_source ProductCostSource @default(BOM)

  material_cost Decimal @default(0) @db.Decimal(15, 2)

  labor_cost Decimal @default(0) @db.Decimal(15, 2)

  overhead_cost Decimal @default(0) @db.Decimal(15, 2)

  total_cost Decimal @default(0) @db.Decimal(15, 2)

  version Int @default(1)

  notes String?

  active Boolean @default(true)

  created_at DateTime @default(now()) @db.Timestamp(6)

  updated_at DateTime? @updatedAt @db.Timestamp(6)

  deleted_at DateTime?

  created_by String? @db.Uuid

  updated_by String? @db.Uuid

  deleted_by String? @db.Uuid

  products products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  currencies currencies @relation(fields: [currency_id], references: [id])

  breakdowns product_cost_breakdowns[]

  @@index([product_id])
  @@index([currency_id])
  @@index([active])
}

model product_cost_breakdowns {
  id String @id @default(uuid()) @db.Uuid

  product_cost_id String @db.Uuid

  component_product_id String @db.Uuid

  component_variant_id String? @db.Uuid

  quantity Decimal @db.Decimal(15, 3)

  unit_cost Decimal @db.Decimal(15, 2)

  total_cost Decimal @db.Decimal(15, 2)

  level Int @default(0)

  created_at DateTime @default(now()) @db.Timestamp(6)

  product_costs product_costs @relation(fields: [product_cost_id], references: [id], onDelete: Cascade)

  component_product products @relation(fields: [component_product_id], references: [id])

  component_variant product_variants? @relation(fields: [component_variant_id], references: [id])

  @@index([product_cost_id])
  @@index([component_product_id])
}

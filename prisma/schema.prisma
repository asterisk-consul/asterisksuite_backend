generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model business_parties {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id      String            @db.Uuid
  type            String            @db.VarChar(20)
  name            String            @db.VarChar(255)
  tax_id          String?           @db.VarChar(50)
  phone           String?           @db.VarChar(50)
  email           String?           @db.VarChar(150)
  active          Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamp(6)
  companies       companies         @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  delivery_notes  delivery_notes[]
  dispatch_orders dispatch_orders[]
  documents       documents[]
  party_locations party_locations[]

  @@index([company_id], map: "idx_parties_company")
  @@index([tax_id], map: "idx_business_parties_tax_id")
}

model cargo_transfer_items {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  transfer_id      String          @db.Uuid
  pallet_id        String?         @db.Uuid
  delivery_note_id String?         @db.Uuid
  quantity         Decimal?        @db.Decimal(12, 3)
  delivery_notes   delivery_notes? @relation(fields: [delivery_note_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pallets          pallets?        @relation(fields: [pallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cargo_transfers  cargo_transfers @relation(fields: [transfer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model cargo_transfers {
  id                                        String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  from_trip_id                              String?                @db.Uuid
  to_trip_id                                String?                @db.Uuid
  location_id                               String?                @db.Uuid
  transfer_time                             DateTime               @default(now()) @db.Timestamp(6)
  performed_by                              String?                @db.Uuid
  notes                                     String?
  cargo_transfer_items                      cargo_transfer_items[]
  trips_cargo_transfers_from_trip_idTotrips trips?                 @relation("cargo_transfers_from_trip_idTotrips", fields: [from_trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations                                 locations?             @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                     users?                 @relation(fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips_cargo_transfers_to_trip_idTotrips   trips?                 @relation("cargo_transfers_to_trip_idTotrips", fields: [to_trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model companies {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                 String                 @db.VarChar(255)
  tax_id               String?                @db.VarChar(50)
  phone                String?                @db.VarChar(30)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  business_parties     business_parties[]
  delivery_notes       delivery_notes[]
  dispatch_orders      dispatch_orders[]
  documentSequences    document_sequences[]
  drivers              drivers[]
  pallets              pallets[]
  picking_orders       picking_orders[]
  products             products[]
  taxes                taxes[]
  trips                trips[]
  users                users[]
  vehicle_combinations vehicle_combinations[]
  vehicles             vehicles[]
  warehouses           warehouses[]
  transfer_rates       transfer_rates[]
}

model delivery_notes {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id           String                 @db.Uuid
  type                 String                 @db.VarChar(20)
  number               String                 @db.VarChar(50)
  status               String                 @db.VarChar(20)
  party_id             String?                @db.Uuid
  trip_id              String?                @db.Uuid
  created_by           String?                @db.Uuid
  deleted_at           DateTime?              @db.Timestamp(6)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  dispatch_order_id    String?                @db.Uuid
  cargo_transfer_items cargo_transfer_items[]
  companies            companies              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                users?                 @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dispatch_orders      dispatch_orders?       @relation(fields: [dispatch_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  business_parties     business_parties?      @relation(fields: [party_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips                trips?                 @relation(fields: [trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_delivery_notes_trip")
  picking_orders       picking_orders[]
  trip_cargo           trip_cargo[]
}

model drivers {
  id                  String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String                 @db.Uuid
  first_name          String                 @db.VarChar(100)
  last_name           String                 @db.VarChar(100)
  document            String?                @db.VarChar(50)
  phone               String?                @db.VarChar(50)
  active              Boolean                @default(true)
  created_at          DateTime               @default(now()) @db.Timestamp(6)
  driverDocuments     documents_driver[]
  companies           companies              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicleCombinations vehicle_combinations[]
}

model entity_photos {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entity_type String   @db.VarChar(30)
  entity_id   String   @db.Uuid
  file_id     String   @db.Uuid
  photo_type  String?  @db.VarChar(30)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  files       files    @relation(fields: [file_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_entity_photos")
}

model files {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  storage_provider String?         @db.VarChar(50)
  file_path        String
  public_url       String?
  file_name        String?         @db.VarChar(255)
  mime_type        String?         @db.VarChar(100)
  file_size        Int?
  uploaded_by      String?         @db.Uuid
  created_at       DateTime        @default(now()) @db.Timestamp(6)
  entity_photos    entity_photos[]
  users            users?          @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model locations {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  address     String?  @db.VarChar(255)
  city        String?  @db.VarChar(100)
  province    String?  @db.VarChar(100)
  country     String?  @db.VarChar(100)
  postal_code String?  @db.VarChar(20)
  latitude    Decimal? @db.Decimal(10, 6)
  longitude   Decimal? @db.Decimal(10, 6)
  created_at  DateTime @default(now()) @db.Timestamp(6)

  cargo_transfers             cargo_transfers[]
  dispatch_orders_destination dispatch_orders[] @relation("dispatch_destination_location")
  dispatch_orders_origin      dispatch_orders[] @relation("dispatch_origin_location")
  party_locations             party_locations[]

  trips_trips_destination_location_idTolocations trips[] @relation("trips_destination_location_idTolocations")
  trips_trips_origin_location_idTolocations      trips[] @relation("trips_origin_location_idTolocations")

  warehouses warehouses[]

  corridor_origin      corridors[] @relation("corridor_origin")
  corridor_destination corridors[] @relation("corridor_destination")

  corridorStops corridor_stops[]
}

model pallet_items {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pallet_id  String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Decimal  @db.Decimal(12, 3)
  pallets    pallets  @relation(fields: [pallet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([pallet_id, product_id])
}

model pallets {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id           String                 @db.Uuid
  code                 String                 @unique @db.VarChar(100)
  warehouse_id         String?                @db.Uuid
  status               String                 @db.VarChar(20)
  created_by           String?                @db.Uuid
  deleted_at           DateTime?              @db.Timestamp(6)
  created_at           DateTime               @default(now()) @db.Timestamp(6)
  cargo_transfer_items cargo_transfer_items[]
  pallet_items         pallet_items[]
  companies            companies              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                users?                 @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses           warehouses?            @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  picking_results      picking_results[]
  picking_sources      picking_sources[]
  trip_cargo           trip_cargo[]
}

model party_locations {
  id                                                         String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  party_id                                                   String           @db.Uuid
  location_id                                                String           @db.Uuid
  label                                                      String?          @db.VarChar(100)
  created_at                                                 DateTime         @default(now()) @db.Timestamp(6)
  locations                                                  locations        @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  business_parties                                           business_parties @relation(fields: [party_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  trips_trips_destination_party_location_idToparty_locations trips[]          @relation("trips_destination_party_location_idToparty_locations")
  trips_trips_origin_party_location_idToparty_locations      trips[]          @relation("trips_origin_party_location_idToparty_locations")
}

model picking_items {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  picking_order_id  String            @db.Uuid
  product_id        String            @db.Uuid
  quantity_required Decimal           @db.Decimal(12, 3)
  quantity_picked   Decimal?          @default(0) @db.Decimal(12, 3)
  picking_orders    picking_orders    @relation(fields: [picking_order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products          products          @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  picking_sources   picking_sources[]
}

model picking_orders {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  warehouse_id      String            @db.Uuid
  client_id         String?           @db.Uuid
  status            String            @db.VarChar(20)
  delivery_note_id  String?           @db.Uuid
  trip_id           String?           @db.Uuid
  created_by        String?           @db.Uuid
  created_at        DateTime          @default(now()) @db.Timestamp(6)
  dispatch_order_id String?           @db.Uuid
  picking_items     picking_items[]
  companies         companies?        @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?            @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  delivery_notes    delivery_notes?   @relation(fields: [delivery_note_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dispatch_orders   dispatch_orders?  @relation(fields: [dispatch_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips             trips?            @relation(fields: [trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses        warehouses        @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  picking_results   picking_results[]
}

model picking_results {
  id               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  picking_order_id String         @db.Uuid
  pallet_id        String         @db.Uuid
  pallets          pallets        @relation(fields: [pallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  picking_orders   picking_orders @relation(fields: [picking_order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model picking_sources {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  picking_item_id String        @db.Uuid
  pallet_id       String        @db.Uuid
  quantity        Decimal       @db.Decimal(12, 3)
  pallets         pallets       @relation(fields: [pallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  picking_items   picking_items @relation(fields: [picking_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model products {
  id                        String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                String                      @db.Uuid
  name                      String                      @db.VarChar(255)
  sku                       String?                     @db.VarChar(100)
  requires_refrigeration    Boolean?                    @default(false)
  created_at                DateTime                    @default(now()) @db.Timestamp(6)
  pallet_items              pallet_items[]
  picking_items             picking_items[]
  product_taxes             product_taxes[]
  companies                 companies                   @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouse_stock           warehouse_stock[]
  warehouse_stock_movements warehouse_stock_movements[]
}

model trip_cargo {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trip_id          String          @db.Uuid
  pallet_id        String?         @db.Uuid
  delivery_note_id String?         @db.Uuid
  loaded_at        DateTime?       @db.Timestamp(6)
  unloaded_at      DateTime?       @db.Timestamp(6)
  delivery_notes   delivery_notes? @relation(fields: [delivery_note_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pallets          pallets?        @relation(fields: [pallet_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips            trips           @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([pallet_id], map: "idx_trip_cargo_pallet")
  @@index([trip_id], map: "idx_trip_cargo_trip")
}

model trip_temperature_logs {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trip_id     String   @db.Uuid
  temperature Decimal  @db.Decimal(5, 2)
  recorded_at DateTime @default(now()) @db.Timestamp(6)
  recorded_by String?  @db.Uuid
  users       users?   @relation(fields: [recorded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips       trips    @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model dispatch_orders {
  id                      String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id              String            @db.Uuid
  order_number            String            @db.VarChar(50)
  status                  String            @db.VarChar(20)
  requires_stock          Boolean           @default(false)
  planned_date            DateTime?         @db.Timestamp(6)
  confirmed_at            DateTime?         @db.Timestamp(6)
  customer_id             String?           @db.Uuid
  origin_location_id      String?           @db.Uuid
  destination_location_id String?           @db.Uuid
  created_by              String?           @db.Uuid
  created_at              DateTime          @default(now()) @db.Timestamp(6)
  delivery_notes          delivery_notes[]
  companies               companies         @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                   users?            @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers               business_parties? @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  destination_location    locations?        @relation("dispatch_destination_location", fields: [destination_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  origin_location         locations?        @relation("dispatch_origin_location", fields: [origin_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  picking_orders          picking_orders[]
  trips                   trips[]

  @@unique([company_id, order_number])
  @@index([company_id], map: "idx_dispatch_orders_company_id")
  @@index([status], map: "idx_dispatch_orders_status")
}

model trips {
  id                                                                   String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                                                           String                  @db.Uuid
  reference_number                                                     String?                 @db.VarChar(100)
  vehicle_combination_id                                               String?                 @db.Uuid
  origin_warehouse_id                                                  String?                 @db.Uuid
  destination_warehouse_id                                             String?                 @db.Uuid
  origin_party_location_id                                             String?                 @db.Uuid
  destination_party_location_id                                        String?                 @db.Uuid
  origin_location_id                                                   String?                 @db.Uuid
  destination_location_id                                              String?                 @db.Uuid
  departure_time                                                       DateTime?               @db.Timestamp(6)
  arrival_time                                                         DateTime?               @db.Timestamp(6)
  status                                                               String                  @db.VarChar(20)
  notes                                                                String?
  created_by                                                           String?                 @db.Uuid
  deleted_at                                                           DateTime?               @db.Timestamp(6)
  created_at                                                           DateTime                @default(now()) @db.Timestamp(6)
  dispatch_order_id                                                    String?                 @db.Uuid
  kilometers                                                           Decimal?                @db.Decimal(10, 2)
  cargo_transfers_cargo_transfers_from_trip_idTotrips                  cargo_transfers[]       @relation("cargo_transfers_from_trip_idTotrips")
  cargo_transfers_cargo_transfers_to_trip_idTotrips                    cargo_transfers[]       @relation("cargo_transfers_to_trip_idTotrips")
  delivery_notes                                                       delivery_notes[]
  picking_orders                                                       picking_orders[]
  trip_cargo                                                           trip_cargo[]
  trip_rates                                                           trip_rates[]
  trip_temperature_logs                                                trip_temperature_logs[]
  companies                                                            companies               @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                                users?                  @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations_trips_destination_location_idTolocations                   locations?              @relation("trips_destination_location_idTolocations", fields: [destination_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  party_locations_trips_destination_party_location_idToparty_locations party_locations?        @relation("trips_destination_party_location_idToparty_locations", fields: [destination_party_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses_trips_destination_warehouse_idTowarehouses                warehouses?             @relation("trips_destination_warehouse_idTowarehouses", fields: [destination_warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dispatch_orders                                                      dispatch_orders?        @relation(fields: [dispatch_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations_trips_origin_location_idTolocations                        locations?              @relation("trips_origin_location_idTolocations", fields: [origin_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  party_locations_trips_origin_party_location_idToparty_locations      party_locations?        @relation("trips_origin_party_location_idToparty_locations", fields: [origin_party_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses_trips_origin_warehouse_idTowarehouses                     warehouses?             @relation("trips_origin_warehouse_idTowarehouses", fields: [origin_warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle_combination                                                  vehicle_combinations?   @relation(fields: [vehicle_combination_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  corridors                                                            corridors?              @relation(fields: [corridor_id], references: [id])
  corridor_id                                                          String?                 @db.Uuid

  @@index([company_id], map: "idx_trips_company")
  @@index([status], map: "idx_trips_status")
  @@index([dispatch_order_id], map: "idx_trips_dispatch_order_id")
  @@index([vehicle_combination_id], map: "idx_trips_vehicle_combination_id")
}

model users {
  id                        String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                String?                     @db.Uuid
  name                      String                      @db.VarChar(255)
  email                     String                      @unique @db.VarChar(255)
  password_hash             String?
  role                      String?                     @db.VarChar(30)
  active                    Boolean?                    @default(true)
  created_at                DateTime                    @default(now()) @db.Timestamp(6)
  cargo_transfers           cargo_transfers[]
  delivery_notes            delivery_notes[]
  dispatch_orders           dispatch_orders[]
  files                     files[]
  pallets                   pallets[]
  picking_orders            picking_orders[]
  refreshTokens             refresh_tokens[]
  trip_temperature_logs     trip_temperature_logs[]
  trips                     trips[]
  companies                 companies?                  @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle_combinations      vehicle_combinations[]
  warehouse_stock_movements warehouse_stock_movements[]
}

model vehicles {
  id                           String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                   String                 @db.Uuid
  type                         String                 @db.VarChar(30)
  plate                        String                 @unique @db.VarChar(20)
  brand                        String?                @db.VarChar(100)
  model                        String?                @db.VarChar(100)
  year                         Int?
  max_weight                   Decimal?               @db.Decimal(12, 3)
  max_volume                   Decimal?               @db.Decimal(12, 3)
  refrigeration                Boolean?               @default(false)
  active                       Boolean                @default(true)
  created_at                   DateTime               @default(now()) @db.Timestamp(6)
  vehicleDocuments             documents_vehicle[]
  vehicle_combinations_tractor vehicle_combinations[] @relation("tractor_vehicle")
  vehicle_combinations_trailer vehicle_combinations[] @relation("trailer_vehicle")
  companies                    companies              @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([company_id], map: "idx_vehicles_company")
}

model vehicle_combinations {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String    @db.Uuid
  tractor_id  String    @db.Uuid
  trailer_id  String?   @db.Uuid
  valid_from  DateTime  @db.Timestamp(6)
  valid_until DateTime? @db.Timestamp(6)
  created_by  String?   @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  unit_number String?   @db.VarChar(50)
  driver_id   String?   @db.Uuid
  deleted_at  DateTime?
  deleted_by  String?
  trips       trips[]
  drivers     drivers?  @relation(fields: [driver_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vehicle_comb_driver")
  companies   companies @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users?    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tractor     vehicles  @relation("tractor_vehicle", fields: [tractor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trailer     vehicles? @relation("trailer_vehicle", fields: [trailer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([company_id], map: "idx_vehicle_combinations_company_id")
  @@index([tractor_id], map: "idx_vehicle_combinations_tractor")
  @@index([trailer_id], map: "idx_vehicle_combinations_trailer")
}

model warehouse_stock {
  id                String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  warehouse_id      String     @db.Uuid
  product_id        String     @db.Uuid
  quantity          Decimal    @default(0) @db.Decimal(12, 3)
  reserved_quantity Decimal    @default(0) @db.Decimal(12, 3)
  updated_at        DateTime   @default(now()) @db.Timestamp(6)
  products          products   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses        warehouses @relation(fields: [warehouse_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([warehouse_id, product_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model warehouse_stock_movements {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  warehouse_id   String     @db.Uuid
  product_id     String     @db.Uuid
  movement_type  String     @db.VarChar(20)
  direction      String     @db.VarChar(3)
  quantity       Decimal    @db.Decimal(12, 3)
  reference_type String?    @db.VarChar(30)
  reference_id   String?    @db.Uuid
  notes          String?
  created_at     DateTime   @default(now()) @db.Timestamp(6)
  created_by     String?    @db.Uuid
  users          users?     @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products       products   @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouses     warehouses @relation(fields: [warehouse_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([product_id], map: "idx_stock_movements_product")
  @@index([reference_type, reference_id], map: "idx_stock_movements_ref")
  @@index([warehouse_id], map: "idx_stock_movements_warehouse")
}

model warehouses {
  id                                               String                      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                                       String                      @db.Uuid
  location_id                                      String?                     @db.Uuid
  name                                             String                      @db.VarChar(255)
  code                                             String?                     @db.VarChar(50)
  active                                           Boolean                     @default(true)
  created_at                                       DateTime                    @default(now()) @db.Timestamp(6)
  pallets                                          pallets[]
  picking_orders                                   picking_orders[]
  trips_trips_destination_warehouse_idTowarehouses trips[]                     @relation("trips_destination_warehouse_idTowarehouses")
  trips_trips_origin_warehouse_idTowarehouses      trips[]                     @relation("trips_origin_warehouse_idTowarehouses")
  warehouse_stock                                  warehouse_stock[]
  warehouse_stock_movements                        warehouse_stock_movements[]
  companies                                        companies                   @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations                                        locations?                  @relation(fields: [location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([company_id, code])
}

model document_sequences {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id     String           @db.Uuid
  document_type  String           @db.VarChar(50)
  point_of_sale  String           @db.VarChar(10)
  current_number Int              @default(0)
  prefix         String?          @db.VarChar(20)
  active         Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.Timestamp(6)
  companies      companies        @relation(fields: [company_id], references: [id])
  document_types document_types[]

  @@unique([company_id, document_type, point_of_sale])
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @db.VarChar(255)
  expires_at DateTime  @db.Timestamp(6)
  revoked    Boolean   @default(false)
  revoked_at DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_refresh_tokens_token_hash")
  @@index([user_id], map: "idx_refresh_tokens_user_id")
  @@index([revoked_at], map: "idx_refresh_tokens_revoked_at")
}

model transport_document_types {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String              @db.VarChar(100)
  entity            String              @db.VarChar(20)
  active            Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  documents_driver  documents_driver[]
  documents_vehicle documents_vehicle[]

  @@index([entity], map: "idx_transport_document_types_entity")
}

model documents_vehicle {
  id                       String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vehicle_id               String                   @db.Uuid
  document_type_id         String                   @db.Uuid
  expiration_date          DateTime?                @db.Date
  created_at               DateTime?                @default(now()) @db.Timestamp(6)
  vehicles                 vehicles                 @relation(fields: [vehicle_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vehicle")
  transport_document_types transport_document_types @relation(fields: [document_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vehicle_doc_type")

  @@unique([vehicle_id, document_type_id], map: "unique_vehicle_doc")
  @@index([vehicle_id], map: "idx_documents_vehicle_vehicle")
}

model documents_driver {
  id                       String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  driver_id                String                   @db.Uuid
  document_type_id         String                   @db.Uuid
  expiration_date          DateTime?                @db.Date
  created_at               DateTime?                @default(now()) @db.Timestamp(6)
  drivers                  drivers                  @relation(fields: [driver_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_driver")
  transport_document_types transport_document_types @relation(fields: [document_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_driver_doc_type")

  @@unique([driver_id, document_type_id], map: "unique_driver_doc")
  @@index([driver_id], map: "idx_documents_driver_driver")
}

model transfer_rates {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String       @db.Uuid
  name        String       @db.VarChar(100)
  rate_type   String       @db.VarChar(20)
  description String?
  active      Boolean?     @default(true)
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  companies   companies    @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trip_rates  trip_rates[]
}

model trip_rates {
  id             String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trip_id        String         @db.Uuid
  rate_id        String         @db.Uuid
  value          Decimal        @db.Decimal(12, 2)
  created_at     DateTime?      @default(now()) @db.Timestamp(6)
  transfer_rates transfer_rates @relation(fields: [rate_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips          trips          @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model corridors {
  id         String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String @db.Uuid

  name        String? @db.VarChar(150)
  description String? @db.VarChar(255)

  origin_location_id      String @db.Uuid
  destination_location_id String @db.Uuid

  is_template Boolean @default(true)

  total_distance_km Decimal? @db.Decimal(10, 2)
  estimated_minutes Int?

  active Boolean @default(true)

  created_at DateTime @default(now()) @db.Timestamp(6)

  origin_location      locations @relation("corridor_origin", fields: [origin_location_id], references: [id])
  destination_location locations @relation("corridor_destination", fields: [destination_location_id], references: [id])

  corridorStops corridor_stops[]

  trips trips[]

  @@unique([company_id, name])
}

model corridor_stops {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  corridor_id String @db.Uuid
  location_id String @db.Uuid

  stop_order Int
  stop_type  String? @db.VarChar(30)

  distance_km       Decimal? @db.Decimal(10, 2)
  estimated_minutes Int?

  created_at DateTime @default(now()) @db.Timestamp(6)

  corridor corridors @relation(fields: [corridor_id], references: [id], onDelete: Cascade)
  location locations @relation(fields: [location_id], references: [id])

  @@unique([corridor_id, stop_order])
}

model document_item_taxes {
  id               String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  document_item_id String         @db.Uuid
  tax_id           String         @db.Uuid
  tax_rate         Decimal        @db.Decimal(6, 3)
  tax_amount       Decimal        @db.Decimal(15, 2)
  created_at       DateTime?      @default(now()) @db.Timestamp(6)
  document_items   document_items @relation(fields: [document_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "dit_document_item_fkey")
  taxes            taxes          @relation(fields: [tax_id], references: [id], onUpdate: NoAction, map: "dit_tax_fkey")

  @@index([document_item_id], map: "idx_document_item_taxes_document_item")
  @@index([tax_id], map: "idx_document_item_taxes_tax")
}

model document_items {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id         String                @db.Uuid
  product_id          String?               @db.Uuid
  quantity            Decimal               @db.Decimal(15, 3)
  price               Decimal               @db.Decimal(15, 2)
  created_at          DateTime              @default(now()) @db.Timestamp(6)
  unit_price          Decimal               @default(0) @db.Decimal(15, 2)
  document_item_taxes document_item_taxes[]
  documents           documents             @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model document_taxes {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id  String    @db.Uuid
  tax_id       String    @db.Uuid
  tax_rate     Decimal   @db.Decimal(6, 3)
  taxable_base Decimal   @db.Decimal(15, 2)
  tax_amount   Decimal   @db.Decimal(15, 2)
  created_at   DateTime  @default(now()) @db.Timestamp(6)
  documents    documents @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  taxes        taxes     @relation(fields: [tax_id], references: [id], onUpdate: NoAction)
}

model document_types {
  id                   String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  document_sequence_id String?             @db.Uuid
  code                 String              @unique @db.VarChar(20)
  description          String              @db.VarChar(150)
  direction            Int                 @db.SmallInt
  affects_stock        Boolean             @default(false)
  affects_accounting   Boolean             @default(false)
  active               Boolean             @default(true)
  document_sequences   document_sequences? @relation(fields: [document_sequence_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  documents            documents[]
}

model documents {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_type_id String            @db.Uuid
  party_id         String?           @db.Uuid
  number           Int
  date             DateTime          @db.Date
  status           Int               @default(0) @db.SmallInt
  created_at       DateTime          @default(now()) @db.Timestamp(6)
  updated_at       DateTime          @default(now()) @db.Timestamp(6)
  subtotal         Decimal           @default(0) @db.Decimal(15, 2)
  total_taxes      Decimal           @default(0) @db.Decimal(15, 2)
  total            Decimal           @default(0) @db.Decimal(15, 2)
  descrip          String?           @db.VarChar(50)
  document_items   document_items[]
  document_taxes   document_taxes[]
  document_types   document_types    @relation(fields: [document_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  business_parties business_parties? @relation(fields: [party_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([document_type_id, number], map: "uq_document_number")
}

model product_taxes {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  product_id           String   @db.Uuid
  tax_id               String   @db.Uuid
  is_included_in_price Boolean  @default(false)
  active               Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamp(6)
  products             products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  taxes                taxes    @relation(fields: [tax_id], references: [id], onUpdate: NoAction)

  @@unique([product_id, tax_id], map: "uq_product_tax")
}

model taxes {
  id                  String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String                @db.Uuid
  code                String                @db.VarChar(20)
  name                String                @db.VarChar(100)
  tax_type            String                @db.VarChar(30)
  rate                Decimal               @db.Decimal(6, 3)
  is_percentage       Boolean               @default(true)
  active              Boolean               @default(true)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  calculation_level   String                @db.VarChar(20)
  document_item_taxes document_item_taxes[]
  document_taxes      document_taxes[]
  product_taxes       product_taxes[]
  companies           companies             @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tax_type, active], map: "idx_taxes_type_active")
}

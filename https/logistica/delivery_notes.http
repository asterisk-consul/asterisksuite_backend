@baseUrl = http://localhost:3000/api

# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{"email":"admin@mail.com","password":"123456"}

###

@accessToken = {{login.response.body.accessToken}}

# ── CREATE ────────────────────────────────────────────────────
###
POST {{baseUrl}}/delivery-notes
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "UUID-DE-TU-EMPRESA",
  "type": "OUTBOUND",
  "pointOfSale": "0001",
  "partyId": "UUID-DEL-CLIENTE",
  "tripId": "UUID-DEL-VIAJE",
  "pickingOrderId": "UUID-DEL-PICKING"
}

# ── FIND ALL ──────────────────────────────────────────────────
###
GET {{baseUrl}}/delivery-notes?company_id=UUID-DE-TU-EMPRESA
Authorization: Bearer {{accessToken}}

# ── FIND ALL con filtros ───────────────────────────────────────
###
GET {{baseUrl}}/delivery-notes?company_id=UUID-DE-TU-EMPRESA&status=DRAFT&type=OUTBOUND
Authorization: Bearer {{accessToken}}

# ── FIND ONE ──────────────────────────────────────────────────
###
GET {{baseUrl}}/delivery-notes/UUID-DEL-REMITO
Authorization: Bearer {{accessToken}}

# ── UPDATE ────────────────────────────────────────────────────
###
PATCH {{baseUrl}}/delivery-notes/UUID-DEL-REMITO
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "type": "INBOUND"
}

# ── CONFIRM ───────────────────────────────────────────────────
###
POST {{baseUrl}}/delivery-notes/UUID-DEL-REMITO/confirm
Authorization: Bearer {{accessToken}}

# ── DELETE ────────────────────────────────────────────────────
###
DELETE {{baseUrl}}/delivery-notes/UUID-DEL-REMITO
Authorization: Bearer {{accessToken}}

# ── PDF ───────────────────────────────────────────────────────
###
GET {{baseUrl}}/delivery-notes/UUID-DEL-REMITO/pdf
Authorization: Bearer {{accessToken}}




###

### =========================================================
### CREATE CUSTOM UNIT
### =========================================================

POST {{baseUrl}}/erp/units
Content-Type: application/json

{
  "name": "Litro",
  "symbol": "lt",
  "unit_type": "VOLUME",
  "active": true
}

###

### =========================================================
### GET ALL UNITS
### =========================================================

GET {{baseUrl}}/erp/units

###

### =========================================================
### GET ONE UNIT
### =========================================================

GET {{baseUrl}}/erp/units/{{unitId}}

###

### =========================================================
### UPDATE UNIT
### =========================================================

PATCH {{baseUrl}}/erp/units/{{unitId}}
Content-Type: application/json

{
  "name": "Kilogramo actualizado",
  "symbol": "kg",
  "active": true
}

###

### =========================================================
### DISABLE UNIT
### =========================================================

PATCH {{baseUrl}}/erp/units/{{unitId}}
Content-Type: application/json

{
  "active": false
}

###

### =========================================================
### DELETE UNIT (SOFT DELETE)
### =========================================================

DELETE {{baseUrl}}/erp/units/{{unitId}}

###
### Variables
@baseUrl = http://localhost:3000/api
#@baseUrl = https://apidonandres.asterisksuite.cloud/api
@contactId = 00000000-0000-0000-0000-000000000000
@partyId = 00000000-0000-0000-0000-000000000001

###
# ==============================
# 🔐 LOGIN
# ==============================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

###  <-- este separador es clave

@accessToken = {{login.response.body.accessToken}}


### ─────────────────────────────────────────
### POST  /party-contacts  → Crear contacto
### ─────────────────────────────────────────
POST {{baseUrl}}/party-contacts
Content-Type: application/json

{
  "party_id": "{{partyId}}",
  "first_name": "Juan",
  "last_name": "Pérez",
  "role": "Gerente Comercial",
  "phone": "+54 9 351 000-0000",
  "email": "juan.perez@empresa.com"
}


### ─────────────────────────────────────────
### POST  sin party_id ni campos opcionales
### ─────────────────────────────────────────
POST {{baseUrl}}/party-contacts
Content-Type: application/json

{
  "first_name": "María",
  "last_name": "González"
}


### ─────────────────────────────────────────
### GET  /party-contacts  → Todos los contactos
### ─────────────────────────────────────────
GET {{baseUrl}}/party-contacts


### ─────────────────────────────────────────
### GET  /party-contacts?party_id=  → Filtrar por empresa
### ─────────────────────────────────────────
GET {{baseUrl}}/party-contacts?party_id={{partyId}}


### ─────────────────────────────────────────
### GET  /party-contacts/:id  → Un contacto
### ─────────────────────────────────────────
GET {{baseUrl}}/party-contacts/{{contactId}}


### ─────────────────────────────────────────
### GET  id inválido (debe devolver 400)
### ─────────────────────────────────────────
GET {{baseUrl}}/party-contacts/not-a-uuid


### ─────────────────────────────────────────
### GET  id inexistente (debe devolver 404)
### ─────────────────────────────────────────
GET {{baseUrl}}/party-contacts/ffffffff-ffff-ffff-ffff-ffffffffffff


### ─────────────────────────────────────────
### PATCH /party-contacts/:id  → Actualizar
### ─────────────────────────────────────────
PATCH {{baseUrl}}/party-contacts/{{contactId}}
Content-Type: application/json

{
  "role": "Director de Ventas",
  "phone": "+54 9 351 111-1111",
  "email": "juan.actualizado@empresa.com"
}


### ─────────────────────────────────────────
### PATCH  solo un campo
### ─────────────────────────────────────────
PATCH {{baseUrl}}/party-contacts/{{contactId}}
Content-Type: application/json

{
  "first_name": "Juanito"
}


### ─────────────────────────────────────────
### DELETE /party-contacts/:id  → Eliminar
### ─────────────────────────────────────────
DELETE {{baseUrl}}/party-contacts/{{contactId}}


### ─────────────────────────────────────────
### DELETE  id inexistente (debe devolver 404)
### ─────────────────────────────────────────
DELETE {{baseUrl}}/party-contacts/ffffffff-ffff-ffff-ffff-ffffffffffff

@baseUrl = https://apidonandres.asterisksuite.cloud/api
//@baseUrl = http://localhost:3000/api


@companyId = a060f7ff-0281-4df4-b5b3-cbdf940be31e
@tractorId = 15d104d7-0e1c-402e-8eb5-40b829190558
@trailerId = 38d8a64d-9c93-449e-8abc-77507d7ed779
@driverId = 8876f17f-1302-49fd-90ea-201afa1dbec6
@combinationId = b00399d8-97da-4c6d-ab03-b74dae2bab30
@vehicleId = 15d104d7-0e1c-402e-8eb5-40b829190558
@userid =

###
# ==============================
# 🔐 LOGIN
# ==============================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

###  <-- este separador es clave

@accessToken = {{login.response.body.accessToken}}

###
# =========================================
# VEHICLE COMBINATIONS
# =========================================

###
# Crear combinación completa
POST {{baseUrl}}/vehicle-combinations
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "tractor_id": "{{tractorId}}",
  "trailer_id": "{{trailerId}}",
  "driver_id": "{{driverId}}",
  "unit_number": "INT-001",
  "valid_from": "2026-03-01T00:00:00.000Z"
}

###
# Crear combinación SIN trailer ni driver
POST {{baseUrl}}/vehicle-combinations
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "tractor_id": "{{tractorId}}",
  "unit_number": "INT-002",
  "valid_from": "2026-03-01T00:00:00.000Z"
}

###
# Listar todas las combinaciones
GET {{baseUrl}}/vehicle-combinations?company_id={{companyId}}
Authorization: Bearer {{accessToken}}

###
# Listar combinaciones ACTIVAS
GET {{baseUrl}}/vehicle-combinations/active?company_id={{companyId}}
Authorization: Bearer {{accessToken}}

###
# Buscar combinación por ID
GET {{baseUrl}}/vehicle-combinations/{{combinationId}}
Authorization: Bearer {{accessToken}}

###
# Historial por vehículo (tractor o trailer)
GET {{baseUrl}}/vehicle-combinations/vehicle/{{vehicleId}}
Authorization: Bearer {{accessToken}}

###
# Finalizar combinación activa
PATCH {{baseUrl}}/vehicle-combinations/{{combinationId}}/finish
Authorization: Bearer {{accessToken}}

###
# Actualizar datos de combinación
PATCH {{baseUrl}}/vehicle-combinations/{{combinationId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "unit_number": "INT-003"
}

###
# Actualizar fechas
PATCH {{baseUrl}}/vehicle-combinations/{{combinationId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "valid_until": "2026-12-31T00:00:00.000Z"
}

###
# Soft delete combinación
DELETE {{baseUrl}}/vehicle-combinations/{{combinationId}}
Authorization: Bearer {{accessToken}}
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJmZWZhYmYxYi1jODlkLTQ1ZTgtODNhOS1lNTIzNTJlZDAxNTkiLCJuYW1lIjoiQWRtaW5pc3RyYWRvciIsImVtYWlsIjoiYWRtaW5AbWFpbC5jb20iLCJyb2xlIjoiYWRtaW4iLCJjb21wYW55SWQiOm51bGwsImlhdCI6MTc3Mjc0MzQxMywiZXhwIjoxNzcyNzQ0MzEzfQ.AHcU7A6284xvg78ff1yIvSNKI8piHcCXUgRses7HgsU
@companyId = a060f7ff-0281-4df4-b5b3-cbdf940be31e
@driverId = UUID_DRIVER
@documentTypeLicense = e90d7345-dbe6-4eb6-8034-9980359729e8
@documentTypeMedical = UUID_DOC_TYPE_MEDICAL

###
# ==============================
# 🔐 LOGIN
# ==============================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

### ======================================================
### 1️⃣ Crear driver SIN documentos
### ======================================================

POST {{baseUrl}}/transport/drivers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "first_name": "Juan",
  "last_name": "Pérez",
  "document": "30123456",
  "phone": "3515551234"
}

### ======================================================
### 2️⃣ Crear driver CON un documento
### ======================================================

POST {{baseUrl}}/transport/drivers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "first_name": "Carlos",
  "last_name": "Gómez",
  "document": "28456789",
  "phone": "3514448899",
  "documents": [
    {
      "document_type_id": "{{documentTypeLicense}}",
      "expiration_date": "2026-05-01"
    }
  ]
}

### ======================================================
### 3️⃣ Crear driver CON múltiples documentos
### ======================================================

POST {{baseUrl}}/transport/drivers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "first_name": "Miguel",
  "last_name": "Fernandez",
  "document": "30999888",
  "phone": "3516667777",
  "documents": [
    {
      "document_type_id": "{{documentTypeLicense}}",
      "expiration_date": "2026-05-01"
    },
    {
      "document_type_id": "{{documentTypeMedical}}",
      "expiration_date": "2025-11-15"
    }
  ]
}

### ======================================================
### 4️⃣ Obtener todos los drivers de una empresa
### ======================================================

GET {{baseUrl}}/transport/drivers?company_id={{companyId}}
Authorization: Bearer {{accessToken}}

### ======================================================
### 5️⃣ Obtener driver por ID
### ======================================================

GET {{baseUrl}}/transport/drivers/{{driverId}}
Authorization: Bearer {{accessToken}}

### ======================================================
### 6️⃣ Actualizar datos del driver
### ======================================================

PATCH {{baseUrl}}/transport/drivers/{{driverId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "phone": "3519990000"
}

### ======================================================
### 7️⃣ Actualizar / agregar documentos del driver
### (usa UPSERT por document_type_id)
### ======================================================

PATCH {{baseUrl}}/transport/drivers/{{driverId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "documents": [
    {
      "document_type_id": "{{documentTypeLicense}}",
      "expiration_date": "2027-01-01"
    },
    {
      "document_type_id": "{{documentTypeMedical}}",
      "expiration_date": "2026-10-10"
    }
  ]
}

### ======================================================
### 8️⃣ Eliminar driver
### ======================================================

DELETE {{baseUrl}}/transport/drivers/{{driverId}}
Authorization: Bearer {{accessToken}}
###
# ==============================
# 🔐 LOGIN
# ==============================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

### ======================================================
### 1️⃣ Crear transfer rate
### ======================================================

POST {{baseUrl}}/transfer-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "name": "Por bultos",
  "rate_type": "INTERNAL",
  "description": "bultos",
  "active": true
}

### ======================================================
### 2️⃣ Crear otro tipo de tarifa
### ======================================================

POST {{baseUrl}}/transfer-rates
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "company_id": "{{companyId}}",
  "name": "Transferencia cliente",
  "rate_type": "CLIENT",
  "description": "Transferencia a cliente"
}

### ======================================================
### 3️⃣ Obtener todas las tarifas de transferencia
### ======================================================

GET {{baseUrl}}/transfer-rates?company_id={{companyId}}
Authorization: Bearer {{accessToken}}

### ======================================================
### 4️⃣ Obtener una tarifa por ID
### ======================================================

GET {{baseUrl}}/transfer-rates/{{rateId}}
Authorization: Bearer {{accessToken}}

### ======================================================
### 5️⃣ Actualizar tarifa
### ======================================================

PATCH {{baseUrl}}/transfer-rates/{{rateId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Transferencia entre depósitos",
  "description": "Actualizado",
  "active": true
}

### ======================================================
### 6️⃣ Desactivar tarifa
### ======================================================

PATCH {{baseUrl}}/transfer-rates/{{rateId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "active": false
}

### ======================================================
### 7️⃣ Eliminar tarifa
### ======================================================

DELETE {{baseUrl}}/transfer-rates/{{rateId}}
Authorization: Bearer {{accessToken}}
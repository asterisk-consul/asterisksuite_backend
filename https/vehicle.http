@companyId = a060f7ff-0281-4df4-b5b3-cbdf940be31e
@vehicleId = 3c2c3bc4-77af-4ad8-912f-3dc647aae5b0
@documentTypeVehicle = UUID_DOCUMENT_TYPE_VEHICLE
@documentTypeVehicle2=

@vehicleDocumentId = UUID_DOCUMENTS_VEHICLE


###
# ==============================
# 🔐 LOGIN
# ==============================
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

### =====================================================
### 1️⃣ Crear vehículo SIN documentos
### =====================================================

POST {{baseUrl}}/logistica/vehicles
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "{{companyId}}",
  "type": "CAMION",
  "plate": "ABC123",
  "brand": "Mercedes Benz",
  "model": "Actros",
  "year": 2022,
  "maxWeight": 18000,
  "maxVolume": 45,
  "refrigeration": false
}

### =====================================================
### 2️⃣ Crear vehículo con UN documento
### =====================================================

POST {{baseUrl}}/logistica/vehicles
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "{{companyId}}",
  "type": "CAMION",
  "plate": "DEF456",
  "brand": "Scania",
  "model": "R450",
  "year": 2021,
  "documents": [
    {
      "documentTypeId": "{{documentTypeVehicle}}",
      "expirationDate": "2026-12-31"
    }
  ]
}

### =====================================================
### 3️⃣ Crear vehículo con MÚLTIPLES documentos
### =====================================================

POST {{baseUrl}}/logistica/vehicles
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "companyId": "{{companyId}}",
  "type": "SEMI",
  "plate": "GHI789",
  "documents": [
    {
      "documentTypeId": "{{documentTypeVehicle}}",
      "expirationDate": "2026-12-31"
    },
    {
      "documentTypeId": "{{documentTypeVehicle2}}",
      "expirationDate": "2025-08-15"
    }
  ]
}

### =====================================================
### 4️⃣ Actualizar solo datos básicos
### =====================================================

PATCH {{baseUrl}}/logistica/vehicles/{{vehicleId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "brand": "Volvo",
  "model": "FH16",
  "year": 2023,
  "refrigeration": true
}

### =====================================================
### 5️⃣ Agregar nuevo documento
### =====================================================

PATCH {{baseUrl}}/logistica/vehicles/{{vehicleId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "documents": [
    {
      "documentTypeId": "{{documentTypeVehicle}}",
      "expirationDate": "2027-01-01"
    }
  ]
}

### =====================================================
### 6️⃣ Actualizar vencimiento documento existente
### =====================================================

PATCH {{baseUrl}}/logistica/vehicles/{{vehicleId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "documents": [
    {
      "id": "{{vehicleDocumentId}}",
      "expirationDate": "2028-05-10"
    }
  ]
}

### =====================================================
### 7️⃣ Eliminar documento
### =====================================================

PATCH {{baseUrl}}/logistica/vehicles/{{vehicleId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "documents": [
    {
      "id": "{{vehicleDocumentId}}",
      "remove": true
    }
  ]
}

### =====================================================
### 8️⃣ Desactivar vehículo (soft delete)
### =====================================================

PATCH {{baseUrl}}/logistica/vehicles/{{vehicleId}}/deactivate
Authorization: Bearer {{accessToken}}

### =====================================================
### 9️⃣ Obtener todos los vehículos de una empresa
### =====================================================

GET {{baseUrl}}/logistica/vehicles?companyId={{companyId}}
Authorization: Bearer {{accessToken}}

### =====================================================
### 🔟 Obtener vehículo por ID
### =====================================================

GET {{baseUrl}}/logistica/vehicles/{{vehicleId}}
Authorization: Bearer {{accessToken}}
@baseUrl = http://localhost:3000/api

### 🔐 LOGIN
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

###

@accessToken = {{login.response.body.accessToken}}

### ➕ Crear Tax
POST {{baseUrl}}/taxes
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "Excento",
  "name": "EX",
  "tax_type": "IVA",
  "rate": -10.000,
  "is_percentage": false,
  "active": true,
  "calculation_level": "LINE"
}

###

### 📋 Listar Taxes por empresa
GET {{baseUrl}}/taxes?id 
Authorization: Bearer {{accessToken}}

###

### ✏️ Actualizar Tax
PATCH {{baseUrl}}/taxes/784fbace-ce2f-4fa8-bea3-c73522e5237d
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "IVA2"
  
}
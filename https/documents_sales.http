@baseUrl = http://localhost:3000/api

### 🔐 LOGIN
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@mail.com",
  "password": "123456"
}

###

@accessToken = {{login.response.body.accessToken}}
@docId =
@tripId = REEMPLAZAR_CON_ID_REAL
@partyId = 6199dbb7-d74e-46af-95e5-3ee2e4e793ef
@taxId = 7f2a703e-d2f4-4d21-b528-60a047c2450e
@productId = 593f4d4d-1f0b-4c16-b9ce-15ce1b4e201d
@docTypeId = afad8b42-baca-4c3e-afae-55038be50eec

### =====================================================
### 🚀 Generar borradores de TODOS los viajes completados
### =====================================================

POST {{baseUrl}}/documents/sales/generate-from-all-completed-trips
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Generar borrador de un viaje específico
### =====================================================

POST {{baseUrl}}/documents/sales/generate-from-trip/{{tripId}}
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Listar todos los documentos de venta
### =====================================================

GET {{baseUrl}}/documents/sales
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Listar solo pendientes
### =====================================================

GET {{baseUrl}}/documents/sales?status=1
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Listar solo borradores
### =====================================================

GET {{baseUrl}}/documents/sales?status=0
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Listar por tipo de documento
### =====================================================

GET {{baseUrl}}/documents/sales?documentTypeId={{docTypeId}}
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Obtener documento por ID
### =====================================================

GET {{baseUrl}}/documents/sales/{{docId}}
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Crear documento manual
### =====================================================

POST {{baseUrl}}/documents/sales
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "document_type_id": "{{docTypeId}}",
  "party_id": "{{partyId}}",
  "date": "2026-04-23",
  "descrip": "Factura de Venta",
  "ref": "REF-001",
  "items": [
    {
      "product_id": "{{productId}}",
      "quantity": 4,
      "unit_price": 0
    }
  ]
}

###

### =====================================================
### Actualizar documento
### =====================================================

PATCH {{baseUrl}}/documents/sales/{{docId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "items": [
    {
      "product_id": "{{productId}}",
      "quantity": 2,
      "unit_price": 1000
    }
  ],
  "descrip": "Factura actualizada"
}

###

### =====================================================
### Confirmar documento
### =====================================================

PATCH {{baseUrl}}/documents/sales/{{docId}}/confirm
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Anular documento
### =====================================================

PATCH {{baseUrl}}/documents/sales/{{docId}}/cancel
Authorization: Bearer {{accessToken}}

###

### =====================================================
### Eliminar documento
### =====================================================

DELETE {{baseUrl}}/documents/sales/{{docId}}
Authorization: Bearer {{accessToken}}